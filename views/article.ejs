<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container-narrow">

  <article>
    <% if (typeof preview !== 'undefined' && preview) { %>
    <div style="margin-top:20px;padding:10px 16px;border:1px dashed var(--color-accent);border-radius:var(--radius-md);font-size:13px;color:var(--color-accent-700)">草稿预览（仅管理员可见）· 状态：<%= post.status === 'published' ? '已发布' : (post.status === 'archived' ? '已归档' : '草稿') %> · 来源：<%= post.created_by %> · 在后台「内容管理」中发布</div>
    <% } %>
    <header style="padding:70px 0 42px">
      <a href="/blog" style="font-size:13px">← 返回 AI 资讯</a>
      <p style="font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-accent-700);font-feature-settings:'tnum' 1;margin:28px 0 0"><%= fmtDate(post.published_at) %> · <%= post.category %></p>
      <h1 style="font-weight:400;font-size:clamp(32px,4vw,48px);line-height:1.18;margin:14px 0 0"><%= post.title %></h1>
      <div style="display:flex;align-items:center;gap:13.8px;margin-top:28px;font-size:13px;color:var(--color-neutral-600)">
        <img src="<%- ctImg('site.portrait') || '/assets/alan.png' %>" alt="Alan" style="width:36px;height:36px;border-radius:50%;object-fit:cover;object-position:top;border:1px solid var(--color-divider)">
        <span>Alan</span><span>·</span><span style="font-feature-settings:'tnum' 1">阅读 <%= post.read_minutes %> 分钟</span><span>·</span><span style="font-feature-settings:'tnum' 1"><%= fmtNum(post.views) %> 次阅读</span>
      </div>
    </header>

    <hr class="hairline">

    <div class="article-body"><%- contentHtml %></div>

    <div style="display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap;padding:20px 0;border-top:1px solid var(--color-divider);border-bottom:1px solid var(--color-divider)">
      <div style="display:flex;gap:9.2px"><span class="tag tag-neutral"><%= post.category %></span><span class="tag tag-neutral">AI 落地</span></div>
      <span style="font-size:12px;color:var(--color-neutral-600)">本文由 Alan 撰写 · 小龙虾 / Hermes Agent 辅助整理与校对</span>
    </div>
  </article>

  <div id="article-end" data-slug="<%= post.slug %>" style="height:1px"></div>

  <section style="padding:56px 0 70px">
    <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
      <h2 style="font-weight:400;font-size:28px;margin:0">评论 <span style="font-size:16px;color:var(--color-neutral-600);font-feature-settings:'tnum' 1">· <%= commentCount %></span></h2>
      <span style="font-size:12px;color:var(--color-neutral-600)">评论由 AI Agent 自动检测，常见问题将自动回复</span>
    </div>

    <div style="display:flex;flex-direction:column;margin-top:28px" id="comment-list">
      <% if (comments.length === 0) { %>
      <p style="padding:20px 0;color:var(--color-neutral-600);font-size:14px">还没有评论，来聊两句。</p>
      <% } %>
      <% for (const c of comments) { %>
      <div style="padding:28px 0;border-bottom:1px solid var(--color-divider)">
        <div style="display:flex;align-items:baseline;gap:13.8px;font-size:13px"><span style="font-family:'Cormorant Garamond','Noto Serif SC',serif;font-size:16px"><%= c.author_name %></span><span style="color:var(--color-neutral-600);font-feature-settings:'tnum' 1"><%= fmtDate(c.created_at) %></span></div>
        <p style="font-size:14.5px;line-height:26px;margin:13.8px 0 0;color:color-mix(in srgb, var(--color-text) 82%, transparent)"><%= c.body %></p>
        <% for (const r of c.replies) { %>
        <div style="margin:20px 0 0 28px;padding:20px;border-left:2px solid <%= r.is_agent ? 'var(--color-accent)' : 'var(--color-divider)' %>;<%= r.is_agent ? 'background:var(--color-neutral-100)' : '' %>">
          <div style="display:flex;align-items:baseline;gap:9.2px;flex-wrap:wrap;font-size:13px">
            <span style="font-family:'Cormorant Garamond','Noto Serif SC',serif;font-size:16px"><%= r.author_name %></span>
            <% if (r.agent_label) { %><span class="tag <%= r.is_agent ? 'tag-accent' : 'tag-outline' %>"><%= r.agent_label %></span><% } %>
            <span style="color:var(--color-neutral-600);font-feature-settings:'tnum' 1"><%= fmtDate(r.created_at) %></span>
          </div>
          <p style="font-size:14px;line-height:25px;margin:9.2px 0 0;color:color-mix(in srgb, var(--color-text) 82%, transparent)"><%= r.body %></p>
        </div>
        <% } %>
      </div>
      <% } %>
    </div>

    <form id="comment-form" style="display:flex;flex-direction:column;gap:13.8px;margin-top:42px">
      <span style="font-size:13px;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-accent-700)">写下你的评论</span>
      <% if (user) { %>
      <textarea class="input" id="comment-body" placeholder="以 <%= user.name %> 的身份参与讨论……"></textarea>
      <div style="display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap">
        <span style="font-size:12px;color:var(--color-neutral-600)">常见问题会由 AI 即时回复，其余由 Alan 本人回复</span>
        <button type="submit" class="btn btn-primary" id="comment-submit">发表评论</button>
      </div>
      <p class="form-error" id="comment-msg"></p>
      <% } else { %>
      <textarea class="input" placeholder="登录后参与讨论……" disabled></textarea>
      <div style="display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap">
        <span style="font-size:12px;color:var(--color-neutral-600)">评论需登录 · 常见问题会由 AI 即时回复，其余由 Alan 本人回复</span>
        <a class="btn btn-primary" href="/login?next=/article/<%= post.slug %>" style="text-decoration:none">登录后评论</a>
      </div>
      <% } %>
    </form>
  </section>

  <%- include('partials/footer') %>
</div>

<% if (user) { %>
<script>
(function () {
  var form = document.getElementById('comment-form');
  var list = document.getElementById('comment-list');
  function el(tag, css, text) { var e = document.createElement(tag); if (css) e.style.cssText = css; if (text != null) e.textContent = text; return e; }

  function renderReply(slot, reply) {
    var box = el('div', 'margin:20px 0 0 28px;padding:20px;border-left:2px solid var(--color-accent);background:var(--color-neutral-100)');
    var head = el('div', 'display:flex;align-items:baseline;gap:9.2px;flex-wrap:wrap;font-size:13px');
    head.appendChild(el('span', "font-family:'Cormorant Garamond','Noto Serif SC',serif;font-size:16px", reply.author_name || 'Alan'));
    if (reply.agent_label) { var t = el('span', null, reply.agent_label); t.className = 'tag ' + (reply.is_agent ? 'tag-accent' : 'tag-outline'); head.appendChild(t); }
    box.appendChild(head);
    box.appendChild(el('p', 'font-size:14px;line-height:25px;margin:9.2px 0 0;color:color-mix(in srgb, var(--color-text) 82%, transparent)', reply.body));
    slot.innerHTML = ''; slot.appendChild(box);
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var btn = document.getElementById('comment-submit');
    var msg = document.getElementById('comment-msg');
    var ta = document.getElementById('comment-body');
    var body = ta.value.trim();
    msg.textContent = '';
    if (body.length < 2) { msg.textContent = '评论内容太短了'; return; }
    btn.disabled = true; btn.textContent = '发表中…';
    fetch('/api/comments', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ post_id: <%= post.id %>, body: body }) })
      .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
      .then(function (res) {
        btn.disabled = false; btn.textContent = '发表评论';
        if (!res.ok) { msg.textContent = res.d.error || '发表失败，请稍后再试'; return; }
        ta.value = '';
        var c = res.d.comment;
        var ph = list.querySelector('p'); if (ph && ph.textContent.indexOf('还没有评论') >= 0) ph.remove();
        var card = el('div', 'padding:28px 0;border-bottom:1px solid var(--color-divider)');
        var head = el('div', 'display:flex;align-items:baseline;gap:13.8px;font-size:13px');
        head.appendChild(el('span', "font-family:'Cormorant Garamond','Noto Serif SC',serif;font-size:16px", c.author_name));
        head.appendChild(el('span', 'color:var(--color-neutral-600)', '刚刚'));
        card.appendChild(head);
        card.appendChild(el('p', 'font-size:14.5px;line-height:26px;margin:13.8px 0 0;color:color-mix(in srgb, var(--color-text) 82%, transparent)', c.body));
        var slot = el('div', null);
        var note = el('p', 'margin:14px 0 0 28px;font-size:12.5px;color:var(--color-neutral-600)', '🦞 小龙虾正在查看是否需要回复…');
        slot.appendChild(note);
        card.appendChild(slot);
        list.appendChild(card);
        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        var tries = 0;
        (function poll() {
          tries++;
          fetch('/api/comments/' + c.id + '/reply-status').then(function (r) { return r.json(); }).then(function (d) {
            if (d.reply) { renderReply(slot, d.reply); return; }
            if (d.status === 'skipped') { note.textContent = '该评论已转 Alan 本人回复。'; return; }
            if (tries >= 8) { note.textContent = '回复稍后可见，刷新即可查看。'; return; }
            setTimeout(poll, 1500);
          }).catch(function () { if (tries >= 8) note.textContent = ''; else setTimeout(poll, 1500); });
        })();
      })
      .catch(function () { btn.disabled = false; btn.textContent = '发表评论'; msg.textContent = '网络异常，请稍后再试'; });
  });
})();
</script>
<% } %>
<%- include('partials/tail') %>
