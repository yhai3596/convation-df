# ===== Convation 官网环境配置（复制为 .env 使用）=====

# 运行
NODE_ENV=production
PORT=8203
HOST=127.0.0.1
SITE_URL=https://www.convation.it
SITE_HOST=www.convation.it

# 会话密钥（部署脚本会自动生成随机值）
SESSION_SECRET=

# 管理员（不配置 ADMIN_PASSWORD 则首次启动自动生成，见 data/admin-credentials.txt）
ADMIN_EMAIL=admin@convation.local
ADMIN_PASSWORD=

# —— 可选：LLM 增强（AI 助理 / 评论自动回复）——
# 填入 Key 后自动启用；不填则使用内置模板与 FAQ，功能同样完整。
# Z.AI 国际版： LLM_BASE_URL=https://api.z.ai/api/paas/v4
# 智谱国内版： LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
Z_AI_API_KEY=
LLM_BASE_URL=https://api.z.ai/api/paas/v4
LLM_MODEL=glm-4.5-flash

# —— 可选：SMTP（询价单/报修邮件送达）——
# 不配置则表单只入库（管理后台可查），不发邮件。
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 本地开发演示数据（生产勿开）
# SEED_DEMO=1
