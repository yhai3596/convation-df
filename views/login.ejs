<%- include('partials/head') %>

<div style="min-height:100vh;display:grid;place-items:center;padding:42px 20px;box-sizing:border-box">
  <div style="width:min(400px,100%)">
    <a href="/" style="text-decoration:none;color:inherit;display:flex;justify-content:center;align-items:baseline;gap:10px;font-family:'Cormorant Garamond','Noto Serif SC',serif;font-weight:600;font-size:26px;margin-bottom:36px">Alan<span style="color:var(--color-accent)">.</span><span style="font-family:'Lora','Noto Serif SC',serif;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-neutral-600)">HVAC × AI</span></a>

    <div class="card" style="padding:36px">
      <div style="display:flex;margin-bottom:28px">
        <button type="button" id="tab-login" style="all:unset;box-sizing:border-box;cursor:pointer;flex:1;text-align:center;padding:9px 0;font-size:14px;border-bottom:2px solid var(--color-accent);color:var(--color-accent-700)">登录</button>
        <button type="button" id="tab-reg" style="all:unset;box-sizing:border-box;cursor:pointer;flex:1;text-align:center;padding:9px 0;font-size:14px;border-bottom:2px solid transparent;color:var(--color-text)">注册</button>
      </div>

      <form id="form-login" style="display:flex;flex-direction:column;gap:20px">
        <div class="field"><label>邮箱 · Email</label><input class="input" type="email" id="login-email" placeholder="you@example.com" autocomplete="email"></div>
        <div class="field"><label>密码 · Password</label><input class="input" type="password" id="login-password" placeholder="••••••••" autocomplete="current-password"></div>
        <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" checked>记住我</label>
          <a href="#" id="forgot-link">忘记密码？</a>
        </div>
        <p class="form-error" id="login-error"></p>
        <button type="submit" class="btn btn-primary btn-block">登录</button>
      </form>

      <form id="form-reg" hidden style="display:flex;flex-direction:column;gap:20px">
        <div class="field"><label>姓名 · Name</label><input class="input" type="text" id="reg-name" placeholder="您的姓名" autocomplete="name"></div>
        <div class="field"><label>邮箱 · Email</label><input class="input" type="email" id="reg-email" placeholder="you@example.com" autocomplete="email"></div>
        <div class="field"><label>密码 · Password</label><input class="input" type="password" id="reg-password" placeholder="至少 8 位" autocomplete="new-password"></div>
        <label style="display:flex;align-items:flex-start;gap:8px;font-size:12.5px;line-height:20px;color:var(--color-neutral-600);cursor:pointer"><input type="checkbox" id="reg-agree" style="margin-top:3px">我同意服务条款与隐私政策，注册后可使用在线工具并购买课程</label>
        <p class="form-error" id="reg-error"></p>
        <button type="submit" class="btn btn-primary btn-block">创建账号</button>
      </form>

      <div style="display:flex;align-items:center;gap:13.8px;margin:28px 0 20px"><span style="flex:1;height:1px;background:var(--color-divider)"></span><span style="font-size:12px;color:var(--color-neutral-600)">或</span><span style="flex:1;height:1px;background:var(--color-divider)"></span></div>
      <button type="button" class="btn btn-secondary btn-block" id="wechat-btn">微信扫码登录</button>
    </div>

    <p style="text-align:center;font-size:13px;color:var(--color-neutral-600);margin-top:28px"><a href="/">← 返回首页</a></p>
  </div>
</div>

<script>
(function () {
  var NEXT = <%- JSON.stringify(next) %>;
  var tabLogin = document.getElementById('tab-login');
  var tabReg = document.getElementById('tab-reg');
  var formLogin = document.getElementById('form-login');
  var formReg = document.getElementById('form-reg');

  function setTab(mode) {
    var isLogin = mode === 'login';
    formLogin.hidden = !isLogin;
    formReg.hidden = isLogin;
    tabLogin.style.borderBottomColor = isLogin ? 'var(--color-accent)' : 'transparent';
    tabLogin.style.color = isLogin ? 'var(--color-accent-700)' : 'var(--color-text)';
    tabReg.style.borderBottomColor = !isLogin ? 'var(--color-accent)' : 'transparent';
    tabReg.style.color = !isLogin ? 'var(--color-accent-700)' : 'var(--color-text)';
  }
  tabLogin.addEventListener('click', function () { setTab('login'); });
  tabReg.addEventListener('click', function () { setTab('reg'); });

  function post(url, data, errEl) {
    errEl.textContent = '';
    return fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) })
      .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
      .then(function (res) {
        if (!res.ok) { errEl.textContent = res.d.error || '操作失败，请稍后再试'; return null; }
        return res.d;
      })
      .catch(function () { errEl.textContent = '网络异常，请稍后再试'; return null; });
  }
  function sid() { return window.AlanTrack ? AlanTrack.sid : ''; }

  formLogin.addEventListener('submit', function (e) {
    e.preventDefault();
    post('/api/auth/login', {
      email: document.getElementById('login-email').value,
      password: document.getElementById('login-password').value,
      sid: sid()
    }, document.getElementById('login-error')).then(function (d) {
      if (d) location.href = d.user && d.user.role === 'admin' && NEXT === '/' ? '/admin' : NEXT;
    });
  });

  formReg.addEventListener('submit', function (e) {
    e.preventDefault();
    post('/api/auth/register', {
      name: document.getElementById('reg-name').value,
      email: document.getElementById('reg-email').value,
      password: document.getElementById('reg-password').value,
      agree: document.getElementById('reg-agree').checked,
      sid: sid()
    }, document.getElementById('reg-error')).then(function (d) {
      if (d) location.href = NEXT;
    });
  });

  document.getElementById('wechat-btn').addEventListener('click', function () {
    alanToast('微信扫码登录即将开通，可先使用邮箱注册登录。');
  });
  document.getElementById('forgot-link').addEventListener('click', function (e) {
    e.preventDefault();
    alanToast('密码找回功能即将开通，可在「关于」页留言联系 Alan 重置。');
  });
})();
</script>
<%- include('partials/tail', { noAssistant: true }) %>
