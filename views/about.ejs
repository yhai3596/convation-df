<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">

  <section class="grid-about">
    <figure style="margin:0;width:min(340px,100%)">
      <img src="<%- ctImg('site.portrait') || '/assets/alan.png' %>" alt="Alan" style="width:100%;aspect-ratio:876/970;object-fit:cover;mix-blend-mode:multiply;filter:sepia(0.18) saturate(0.85) contrast(1.04);-webkit-mask-image:radial-gradient(92% 74% at 50% 38%, black 32%, rgba(0,0,0,0.6) 58%, transparent 81%);mask-image:radial-gradient(92% 74% at 50% 38%, black 32%, rgba(0,0,0,0.6) 58%, transparent 81%)">
    </figure>
    <div>
      <span class="kicker" style="font-feature-settings:normal">关于 · About</span>
      <h1 style="font-weight:400;font-size:clamp(38px,4.6vw,58px);line-height:1.12;margin:0">Alan</h1>
      <p style="font-size:15px;line-height:26px;margin:9.2px 0 0;color:var(--color-neutral-600)"><%- ct('about.subtitle') %></p>
      <p style="font-size:15.5px;line-height:28px;margin:28px 0 0;max-width:56ch;color:color-mix(in srgb, var(--color-text) 82%, transparent);text-align:justify"><%- ct('about.bio') %></p>
      <p style="font-size:13px;line-height:24px;margin:14px 0 0;color:var(--color-neutral-600)"><%- ct('about.bio_en') %></p>

      <hr class="hairline" style="margin:42px 0 28px">

      <span class="kicker" style="font-feature-settings:normal;margin-bottom:20px">联系方式 · Contact</span>
      <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:20px 28px;max-width:560px">
        <div style="display:flex;flex-direction:column;gap:4px"><span style="font-size:12px;color:var(--color-neutral-600)">邮箱 · Email</span><a href="mailto:<%- ct('about.contact_email') %>" style="font-size:15px"><%- ct('about.contact_email') %></a></div>
        <div style="display:flex;flex-direction:column;gap:4px"><span style="font-size:12px;color:var(--color-neutral-600)">微信 · WeChat</span><span style="font-size:15px"><%- ct('about.contact_wechat') %></span></div>
        <div style="display:flex;flex-direction:column;gap:4px"><span style="font-size:12px;color:var(--color-neutral-600)">LinkedIn</span><span style="font-size:15px"><%- ct('about.contact_linkedin') %></span></div>
        <div style="display:flex;flex-direction:column;gap:4px"><span style="font-size:12px;color:var(--color-neutral-600)">公众号 · Official Account</span><span style="font-size:15px"><%- ct('about.contact_mp') %></span></div>
      </div>
    </div>
  </section>

  <hr class="hairline">

  <section class="grid-about" style="padding:56px 0 70px;align-items:start">
    <div>
      <h2 style="font-weight:400;font-size:28px;line-height:1.2;margin:0"><%- ct('about.msg_title') %></h2>
      <p style="font-size:14.5px;line-height:26px;margin:14px 0 0;color:color-mix(in srgb, var(--color-text) 72%, transparent)"><%- ct('about.msg_body') %></p>
    </div>
    <form id="about-form" style="display:flex;flex-direction:column;gap:20px;max-width:560px">
      <div class="grid-form2">
        <div class="field"><label>姓名 · Name</label><input class="input" type="text" id="about-name" placeholder="您的姓名"></div>
        <div class="field"><label>邮箱 · Email</label><input class="input" type="email" id="about-email" placeholder="you@example.com"></div>
      </div>
      <div class="field"><label>留言 · Message</label><textarea class="input" id="about-body" placeholder="想聊点什么？"></textarea></div>
      <div style="display:flex;align-items:center;gap:14px">
        <button type="submit" class="btn btn-primary">发送 · Send</button>
        <p class="form-ok" id="about-msg" style="min-height:auto"></p>
      </div>
    </form>
  </section>

  <%- include('partials/footer') %>
</div>

<script>
document.getElementById('about-form').addEventListener('submit', function (e) {
  e.preventDefault();
  var msg = document.getElementById('about-msg');
  fetch('/api/message', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name: document.getElementById('about-name').value,
      email: document.getElementById('about-email').value,
      body: document.getElementById('about-body').value
    })
  }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
    .then(function (res) {
      msg.className = res.ok ? 'form-ok' : 'form-error';
      msg.textContent = res.ok ? '已收到留言，我会尽快回复。' : (res.d.error || '提交失败');
      if (res.ok) document.getElementById('about-form').reset();
    })
    .catch(function () { msg.className = 'form-error'; msg.textContent = '网络异常，请稍后再试'; });
});
</script>
<%- include('partials/tail') %>
