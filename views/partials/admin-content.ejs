<!-- Notizie 文章管理：草稿待审（Agent/AI 供稿）+ 手动新建 + 归档/删除。课程/工具/案例前台无 DB 消费点（Strumenti/Impianti 走页面内容键），不设入口 -->
<div id="tab-content" hidden>
  <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
    <h1 style="font-weight:400;font-size:34px;margin:0">Notizie 文章 Articles</h1>
    <div style="display:flex;gap:9.2px;flex-wrap:wrap">
      <button type="button" class="btn btn-secondary" id="btn-ai-draft">✎ AI 生成草稿 AI draft</button>
      <button type="button" class="btn btn-primary" data-new="post">+ 新建文章 New post</button>
    </div>
  </div>

  <!-- 草稿待审队列（Agent/AI 生成的内容在此审核发布） -->
  <% if (drafts && drafts.length) { %>
  <div class="card" style="padding:24px;margin-top:20px;border-color:var(--color-accent)">
    <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;flex-wrap:wrap">
      <span class="card-kicker" style="color:var(--color-accent)">待审草稿 · <%= drafts.length %> 篇</span>
      <span style="font-size:12px;color:var(--color-neutral-600)">Agent/AI 生成的内容先入草稿，审核后一键发布</span>
    </div>
    <table class="table" style="margin-top:12px">
      <thead><tr><th>标题</th><th>来源</th><th>更新</th><th style="text-align:right">操作</th></tr></thead>
      <tbody>
        <% for (const d of drafts) { %>
        <tr>
          <td><%= d.title %></td>
          <td><%= d.created_by === 'ai' ? 'AI 生成' : (d.created_by && d.created_by.startsWith('agent:') ? d.created_by.replace('agent:', 'Agent · ') : '手动') %></td>
          <td class="tnum"><%= fmtDate(d.updated_at) %></td>
          <td style="text-align:right;white-space:nowrap">
            <a class="btn btn-ghost" href="/admin/preview/post/<%= d.id %>" target="_blank" rel="noopener">预览</a>
            <button type="button" class="btn btn-ghost" data-edit="post" data-id="<%= d.id %>">编辑</button>
            <button type="button" class="btn btn-primary" data-publish="<%= d.id %>">发布</button>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>

  <div class="card" style="padding:28px;margin-top:20px">
    <table class="table">
      <thead><tr><th>标题 Title</th><th>语言</th><th>状态 Status</th><th>更新 Updated</th><th style="text-align:right">操作</th></tr></thead>
      <tbody id="content-rows">
        <% for (const p of posts) { %>
        <tr data-ctype="post">
          <td><%= p.title %></td><td><span class="tag tag-neutral"><%= (p.lang || 'it').toUpperCase() %></span></td>
          <td><span class="tag <%= p.status === 'published' ? 'tag-accent' : (p.status === 'archived' ? 'tag-neutral' : 'tag-neutral') %>"><%= p.status === 'published' ? '已发布' : (p.status === 'archived' ? '已归档' : '草稿') %></span></td>
          <td class="tnum"><%= fmtDate(p.published_at || p.updated_at) %></td>
          <td style="text-align:right;white-space:nowrap"><button type="button" class="btn btn-ghost" data-edit="post" data-id="<%= p.id %>">编辑</button><button type="button" class="btn btn-ghost" data-del="post" data-id="<%= p.id %>" data-name="<%= p.title %>" data-archived="<%= p.status === 'archived' ? 1 : 0 %>" style="color:#a33d2e"><%= p.status === 'archived' ? '删除' : '下线' %></button></td>
        </tr>
        <% } %>
        <% if (!posts.length) { %><tr><td colspan="5" style="color:var(--color-neutral-600);font-size:13px">还没有文章。点右上「+ 新建文章」，或等 Agent 供稿进入待审草稿。No articles yet.</td></tr><% } %>
      </tbody>
    </table>
  </div>
  <p style="font-size:12px;color:var(--color-neutral-600);margin-top:14px">两段式删除：先点"下线"= 归档（前台 Notizie 立即隐藏，保留评论与统计），归档后再点"删除"才彻底移除。误删可"编辑→状态→已发布"恢复。IT/EN 各自只出现在对应语言版列表。</p>
</div>
