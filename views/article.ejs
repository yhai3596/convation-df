<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container-narrow">

  <!-- 草稿预览（后台专用，仅管理员可见）：纯内容预览，不含评论交互 -->
  <div style="margin-top:20px;padding:10px 16px;border:1px dashed var(--color-accent);border-radius:var(--radius-md);font-size:13px;color:var(--color-accent);display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap">
    <span>草稿预览 · 仅管理员可见 · 状态：<%= post.status === 'published' ? '已发布' : (post.status === 'archived' ? '已归档' : '草稿') %></span>
    <a href="/admin" style="color:inherit">← 返回内容管理</a>
  </div>

  <article>
    <header style="padding:44px 0 30px">
      <span class="kicker"><%= fmtDate(post.published_at) %> · <%= post.category %></span>
      <h1 style="font-size:clamp(30px,3.8vw,46px);line-height:1.16;margin:12px 0 0"><%= post.title %></h1>
      <p style="margin:14px 0 0;font-size:12.5px;color:var(--color-neutral-600)">阅读 <%= post.read_minutes %> 分钟 · <%= fmtNum(post.views) %> 次阅读</p>
    </header>

    <hr class="hairline">

    <div class="article-body"><%- contentHtml %></div>

    <div style="display:flex;gap:9.2px;padding:22px 0;border-top:1px solid var(--color-divider);margin-top:30px">
      <span class="tag tag-neutral"><%= post.category %></span>
    </div>
  </article>

  <p style="padding:8px 0 60px"><a class="card-link" href="/admin">← 返回内容管理</a></p>

  <%- include('partials/footer') %>
</div>
<%- include('partials/tail') %>
