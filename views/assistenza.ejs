<%- include('partials/head') %>
<%- include('partials/nav') %>
<% const en = locale === 'en'; %>
<main>
<section class="page-hero">
  <div class="container">
    <span class="kicker fade-up"><%= en ? 'Support' : 'Assistenza' %></span>
    <h1 class="page-h1 fade-up"><%= ct('assistenza.intro_title') %></h1>
    <p class="page-sub fade-up"><%= ct('assistenza.intro_body') %></p>
  </div>
</section>

<!-- 三支柱：质保/保养/维修 -->
<section class="sect" style="padding-top:clamp(24px,3vw,40px)">
  <div class="container grid-cards3">
    <% for (let i = 1; i <= 3; i++) { %>
    <div class="card fade-up">
      <span class="card-title"><%= ct('assistenza.p' + i + '_title') %></span>
      <p class="card-body"><%= ct('assistenza.p' + i + '_body') %></p>
    </div>
    <% } %>
  </div>
</section>

<!-- 报修三步 -->
<section class="sect band-light">
  <div class="container">
    <div class="sect-head fade-up">
      <span class="kicker"><%= en ? 'How it works' : 'Come funziona' %></span>
      <h2><%= en ? 'Report a fault in three steps' : 'Segnala un guasto in tre passi' %></h2>
    </div>
    <div class="grid-cards3">
      <% const steps = en
        ? [['1 · Tell us', 'Describe the fault with the form below, by phone or via the AI assistant — model and photos help.'],
           ['2 · Diagnosis', 'We call you back within 24 working hours with a first diagnosis and a clear cost estimate.'],
           ['3 · Intervention', 'A certified technician arrives with the right parts. Tested, explained, done.']]
        : [['1 · Segnalaci il problema', 'Descrivi il guasto col modulo qui sotto, per telefono o con l\'assistente AI — modello e foto aiutano.'],
           ['2 · Diagnosi', 'Ti richiamiamo entro 24 ore lavorative con una prima diagnosi e una stima chiara dei costi.'],
           ['3 · Intervento', 'Un tecnico certificato arriva con i ricambi giusti. Collaudato, spiegato, fatto.']]; %>
      <% steps.forEach(s => { %>
      <div class="card fade-up" style="background:var(--color-surface)">
        <span class="card-title" style="font-size:16px;color:var(--color-accent)"><%= s[0] %></span>
        <p class="card-body"><%= s[1] %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- 人工通道 + 报修表单 -->
<section class="sect">
  <div class="container ai-grid">
    <div class="fade-up">
      <span class="kicker"><%= en ? 'Direct channels' : 'Canali diretti' %></span>
      <h2 style="font-size:26px"><%= en ? 'Talk to a person' : 'Parla con una persona' %></h2>
      <% if (channels.length) { %>
      <div style="display:grid;gap:12px;margin-top:16px">
        <% for (const ch of channels) { %>
        <a class="card card-hover" style="padding:16px 20px" href="<%= ch.href %>"><strong><%= ch.label %></strong> · <%= ch.value %></a>
        <% } %>
      </div>
      <% } else { %>
      <p style="font-size:15px"><%= ct('consulenza.human_pending') %></p>
      <% } %>
      <p style="margin-top:16px"><button type="button" class="btn btn-secondary" data-open-assistant><%= ct('home.cta_ai') %></button></p>
    </div>
    <div class="fade-up">
      <span class="kicker"><%= en ? 'Repair request' : 'Richiesta di intervento' %></span>
      <form id="rp-form" style="margin-top:8px">
        <div class="grid-form2">
          <input class="input" id="rp-name" placeholder="<%= en ? 'Name' : 'Nome' %>" maxlength="40" required>
          <input class="input" id="rp-email" type="email" placeholder="Email" maxlength="80" required>
        </div>
        <input class="input" id="rp-phone" style="margin-top:14px" placeholder="<%= en ? 'Phone (optional)' : 'Telefono (facoltativo)' %>" maxlength="30">
        <textarea class="input" id="rp-body" rows="4" style="margin-top:14px" placeholder="<%= en ? 'What happens? Brand and model, error code, since when…' : 'Cosa succede? Marca e modello, codice errore, da quando…' %>" required></textarea>
        <div style="display:flex;gap:14px;align-items:center;margin-top:14px">
          <button type="submit" class="btn btn-primary"><%= en ? 'Send report' : 'Invia segnalazione' %></button>
          <p class="form-error" id="rp-msg" style="min-height:0;margin:0"></p>
        </div>
      </form>
    </div>
  </div>
</section>
</main>
<%- include('partials/footer') %>
<script>
document.getElementById('rp-form').addEventListener('submit', function (e) {
  e.preventDefault();
  var en = <%= en ? 'true' : 'false' %>;
  var msg = document.getElementById('rp-msg');
  var phone = document.getElementById('rp-phone').value.trim();
  var body = '[' + (en ? 'Repair' : 'Riparazione') + ']' + (phone ? ' tel: ' + phone : '') + '\n' + document.getElementById('rp-body').value.trim();
  fetch('/api/message', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: document.getElementById('rp-name').value.trim(), email: document.getElementById('rp-email').value.trim(), body: body }) })
    .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
    .then(function (res) {
      msg.className = res.ok ? 'form-ok' : 'form-error';
      msg.textContent = res.ok ? (en ? 'Sent. We call back within 24 working hours.' : 'Inviata. Ti richiamiamo entro 24 ore lavorative.') : (res.d.error || (en ? 'Could not send' : 'Invio non riuscito'));
      if (res.ok) document.getElementById('rp-form').reset();
    })
    .catch(function () { msg.className = 'form-error'; msg.textContent = en ? 'Network error' : 'Errore di rete'; });
});
</script>
<%- include('partials/tail') %>
