<%- include('partials/head') %>

<div class="admin-shell">

  <aside class="admin-aside">
    <a href="/" style="text-decoration:none;color:inherit;display:flex;align-items:baseline;gap:8px;font-family:var(--font-heading);font-weight:700;font-size:17px">Convation<span style="font-size:9px;letter-spacing:0.16em;text-transform:uppercase;color:var(--color-neutral-600)">Admin</span></a>
    <nav style="display:flex;flex-direction:column;gap:4px">
      <button type="button" class="admin-navbtn on" data-admin-tab="dash">数据看板 <small>DASHBOARD</small></button>
      <button type="button" class="admin-navbtn" data-admin-tab="leads">询价线索 <small>LEADS</small></button>
      <button type="button" class="admin-navbtn" data-admin-tab="content">Notizie 文章 <small>POSTS</small></button>
      <button type="button" class="admin-navbtn" data-admin-tab="pages">页面内容 <small>PAGE CONTENT</small></button>
      <button type="button" class="admin-navbtn" data-admin-tab="agent">智能助理 <small>AGENT</small></button>
      <button type="button" class="admin-navbtn" data-admin-tab="users">用户与留言 <small>USERS</small></button>
    </nav>
    <div style="margin-top:auto;display:flex;flex-direction:column;gap:9px;font-size:12px;color:var(--color-neutral-600)">
      <a href="/" style="color:inherit">← 返回前台</a>
      <span><%= user.email %></span>
      <a href="#" id="nav-logout" style="color:inherit">退出登录</a>
    </div>
  </aside>

  <main style="padding:36px clamp(24px,4vw,56px);max-width:1100px;box-sizing:border-box">

    <!-- ═══════════ 数据看板 ═══════════ -->
    <div id="tab-dash">
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <h1 style="font-weight:400;font-size:34px;margin:0">数据看板</h1>
        <div class="seg">
          <label class="seg-opt"><input type="radio" name="range" value="7" <%= range === '7' ? 'checked' : '' %>>7 天</label>
          <label class="seg-opt"><input type="radio" name="range" value="30" <%= range === '30' ? 'checked' : '' %>>30 天</label>
          <label class="seg-opt"><input type="radio" name="range" value="all" <%= range === 'all' ? 'checked' : '' %>>全部</label>
        </div>
      </div>

      <div class="grid-cards4" style="margin-top:28px">
        <div class="card" style="padding:20px"><span class="card-kicker">页面访问 · PV</span><span class="tnum" style="font-family:var(--font-heading);font-size:34px"><%= fmtNum(dash.pv) %></span><span class="card-meta"><%= dash.pvDelta %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">独立访客 · UV</span><span class="tnum" style="font-family:var(--font-heading);font-size:34px"><%= fmtNum(dash.uv) %></span><span class="card-meta"><%= dash.uvDelta %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">待处理询价 · New leads</span><span class="tnum" style="font-family:var(--font-heading);font-size:34px;color:var(--color-accent)"><%= fmtNum(counts.inquiriesNew) %></span><span class="card-meta">共 <%= fmtNum(counts.inquiries) %> 条</span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">注册用户 · Users</span><span class="tnum" style="font-family:var(--font-heading);font-size:34px"><%= fmtNum(dash.usersTotal) %></span><span class="card-meta">本月新增 <%= fmtNum(dash.usersMonth) %></span></div>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline"><span class="card-kicker">访问趋势 · Traffic</span><span class="card-meta tnum"><%= dash.trend.length ? dash.trend[0].d.slice(5).replace('-', '.') + ' – ' + dash.trend[dash.trend.length - 1].d.slice(5).replace('-', '.') : '' %></span></div>
        <svg viewBox="0 0 720 180" style="width:100%;height:auto;margin-top:14px" role="img" aria-label="访问趋势折线图">
          <line x1="0" y1="45" x2="720" y2="45" stroke="var(--color-divider)" stroke-width="1"></line>
          <line x1="0" y1="90" x2="720" y2="90" stroke="var(--color-divider)" stroke-width="1"></line>
          <line x1="0" y1="135" x2="720" y2="135" stroke="var(--color-divider)" stroke-width="1"></line>
          <line x1="0" y1="179" x2="720" y2="179" stroke="var(--color-neutral-400)" stroke-width="1"></line>
          <polyline fill="none" stroke="var(--color-neutral-400)" stroke-width="1.5" points="<%= uvPoints %>"></polyline>
          <polyline fill="none" stroke="var(--color-accent)" stroke-width="2" points="<%= pvPoints %>"></polyline>
          <% const lastPt = pvPoints.split(' ').pop().split(','); %>
          <circle cx="<%= lastPt[0] %>" cy="<%= lastPt[1] %>" r="3.5" fill="var(--color-accent)"></circle>
        </svg>
        <div style="display:flex;gap:20px;font-size:12px;color:var(--color-neutral-600);margin-top:9px">
          <span style="display:flex;align-items:center;gap:6px"><span style="width:16px;height:2px;background:var(--color-accent);display:inline-block"></span>页面访问 PV</span>
          <span style="display:flex;align-items:center;gap:6px"><span style="width:16px;height:1.5px;background:var(--color-neutral-400);display:inline-block"></span>独立访客 UV</span>
        </div>
      </div>

      <div class="grid-cards2" style="gap:20px;margin-top:20px">
        <div class="card" style="padding:28px">
          <span class="card-kicker">流量来源 · Sources</span>
          <div style="display:flex;flex-direction:column;gap:13.8px;margin-top:9.2px;font-size:13.5px">
            <% for (const s of dash.sources) { %>
            <div class="bar-row"><span><%= s.label %></span><div style="height:6px;border:1px solid var(--color-divider)"><div style="height:100%;width:<%= s.pct %>%;background:var(--color-accent-300)"></div></div><span class="tnum" style="text-align:right"><%= s.pct %>%</span></div>
            <% } %>
          </div>
        </div>
        <div class="card" style="padding:28px">
          <span class="card-kicker">文章阅读 Top 5 · Reads</span>
          <% if (dash.topPosts.length === 0) { %>
          <p style="font-size:13px;color:var(--color-neutral-600);margin:14px 0 0">暂无已发布文章。No published posts yet.</p>
          <% } else { %>
          <table class="table" style="margin-top:9.2px">
            <thead><tr><th>文章</th><th style="text-align:right">阅读</th></tr></thead>
            <tbody>
              <% for (const p of dash.topPosts) { %>
              <tr><td><%= p.title %></td><td class="tnum" style="text-align:right"><%= fmtNum(p.views) %></td></tr>
              <% } %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ═══════════ 询价线索 ═══════════ -->
    <div id="tab-leads" hidden>
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <h1 style="font-weight:400;font-size:34px;margin:0">询价线索 <span style="font-size:14px;color:var(--color-neutral-600)">Leads</span></h1>
        <span class="card-meta">待处理 <%= fmtNum(counts.inquiriesNew) %> / 共 <%= fmtNum(counts.inquiries) %> 条 · 最近 100 条</span>
      </div>
      <div class="card" style="padding:28px;margin-top:28px">
        <% if (inquiries.length === 0) { %>
        <p style="font-size:13px;color:var(--color-neutral-600);margin:0">暂无询价。前台「Consulenza / Assistenza / Contatti」三表单提交后在此汇总。</p>
        <% } else { %>
        <div style="display:flex;flex-direction:column">
          <% const KIND_LABEL = { preventivo: '询价 Preventivo', riparazione: '报修 Riparazione', contatto: '联系 Contatto' }; %>
          <% for (const q of inquiries) { %>
          <div style="padding:14px 0;border-bottom:1px solid var(--color-divider)" data-inq-row="<%= q.id %>">
            <div style="display:flex;gap:12px;align-items:baseline;font-size:13px;flex-wrap:wrap">
              <span class="tag" style="<%= q.status === 'new' ? 'border-color:var(--color-accent);color:var(--color-accent)' : '' %>"><%= KIND_LABEL[q.kind] || q.kind %></span>
              <% if (q.topic) { %><span style="color:var(--color-neutral-600)"><%= q.topic %></span><% } %>
              <strong><%= q.name %></strong>
              <a href="mailto:<%= q.email %>" style="color:var(--color-neutral-600)"><%= q.email %></a>
              <% if (q.phone) { %><span class="tnum" style="color:var(--color-neutral-600)"><%= q.phone %></span><% } %>
              <span style="color:var(--color-neutral-600);text-transform:uppercase;font-size:11px"><%= q.lang %></span>
              <span class="tnum" style="color:var(--color-neutral-600)"><%= fmtDT(q.created_at) %></span>
              <button type="button" class="btn btn-secondary" style="margin-left:auto;padding:4px 12px;font-size:12px" data-inq-status="<%= q.id %>" data-next="<%= q.status === 'new' ? 'handled' : 'new' %>"><%= q.status === 'new' ? '标记已处理 Done' : '已处理 ↩ 撤销' %></button>
            </div>
            <p style="font-size:13.5px;line-height:24px;margin:6px 0 0;color:color-mix(in srgb, var(--color-text) 80%, transparent)"><%= q.body %></p>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- ═══════════ 内容管理 / 页面内容 / Agent 自动化 ═══════════ -->
    <%- include('partials/admin-content') %>
    <%- include('partials/admin-pages') %>
    <%- include('partials/admin-agent') %>

    <!-- ═══════════ 用户管理 ═══════════ -->
    <div id="tab-users" hidden>
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:20px;flex-wrap:wrap">
        <h1 style="font-weight:400;font-size:34px;margin:0">用户管理</h1>
        <input class="input" type="search" id="user-search" placeholder="搜索用户 / Search" style="max-width:240px">
      </div>
      <div class="grid-cards3" style="gap:20px;margin-top:28px">
        <div class="card" style="padding:20px"><span class="card-kicker">注册用户 · Users</span><span class="tnum" style="font-family:var(--font-heading);font-size:34px"><%= fmtNum(dash.usersTotal) %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">本月新增 · New this month</span><span class="tnum" style="font-family:var(--font-heading);font-size:34px;color:var(--color-accent)"><%= fmtNum(dash.usersMonth) %></span></div>
        <div class="card" style="padding:20px"><span class="card-kicker">Newsletter 订阅 · Subscribers</span><span class="tnum" style="font-family:var(--font-heading);font-size:34px"><%= fmtNum(counts.subscribers) %></span></div>
      </div>
      <div class="card" style="padding:28px;margin-top:20px">
        <table class="table">
          <thead><tr><th>用户 User</th><th>角色 Role</th><th>注册时间 Registered</th><th>来源 Source</th></tr></thead>
          <tbody id="user-rows">
            <% for (const u of users) { %>
            <tr><td><%= u.name %> · <%= u.email %></td><td><%= u.role === 'admin' ? '管理员 Admin' : '安装工 Installer' %></td><td class="tnum"><%= fmtDate(u.created_at) %></td><td><%= u.source %></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="card" style="padding:28px;margin-top:20px">
        <div style="display:flex;justify-content:space-between;align-items:baseline"><span class="card-kicker">站内留言 · Messages（旧通道，新表单见「询价线索」）</span><span class="card-meta">最近 10 条 · 共 <%= fmtNum(counts.messages) %> 条</span></div>
        <% if (messages.length === 0) { %>
        <p style="font-size:13px;color:var(--color-neutral-600);margin:14px 0 0">暂无留言。</p>
        <% } else { %>
        <div style="display:flex;flex-direction:column;margin-top:9.2px">
          <% for (const m of messages) { %>
          <div style="padding:13.8px 0;border-bottom:1px solid var(--color-divider)">
            <div style="display:flex;gap:13.8px;align-items:baseline;font-size:13px;flex-wrap:wrap"><span style="font-size:14px"><%= m.name || '（未署名）' %></span><span style="color:var(--color-neutral-600)"><%= m.email %></span><span class="tnum" style="color:var(--color-neutral-600)"><%= fmtDate(m.created_at) %></span></div>
            <p style="font-size:13.5px;line-height:24px;margin:6px 0 0;color:color-mix(in srgb, var(--color-text) 80%, transparent)"><%= m.body %></p>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>

  </main>
</div>

<!-- 编辑对话框 -->
<div class="dialog-backdrop" id="edit-backdrop" hidden style="z-index:90">
  <div class="dialog" style="width:min(640px,100%);max-height:88vh;overflow-y:auto">
    <span class="dialog-title" id="edit-title">编辑</span>
    <div class="dialog-body" id="edit-fields" style="display:flex;flex-direction:column;gap:14px"></div>
    <p class="form-error" id="edit-error"></p>
    <div class="dialog-actions">
      <button type="button" class="btn btn-secondary" id="edit-cancel">取消</button>
      <button type="button" class="btn btn-primary" id="edit-save">保存</button>
    </div>
  </div>
</div>

<script type="application/json" id="admin-data"><%- JSON.stringify({
  posts: posts.map(p => ({ id: p.id, title: p.title, category: p.category, excerpt: p.excerpt, content_md: p.content_md, read_minutes: p.read_minutes, status: p.status })),
  courses: courses.map(c => ({ id: c.id, title: c.title, description: c.description, lectures: c.lectures, price_yuan: c.price_cents == null ? '' : Math.round(c.price_cents / 100), status: c.status, tag: c.tag, kicker: c.kicker, cover_url: c.cover_url || '' })),
  tools: tools.map(t => ({ id: t.id, name: t.name, description: t.description, status: t.status, url: t.url })),
  cases: cases.map(c => ({ id: c.id, org: c.org, title: c.title, description: c.description, metric_value: c.metric_value, metric_label: c.metric_label, sort: c.sort })),
}) %></script>
<script src="/js/admin.js?v=<%= assetVer %>" defer></script>
<script src="/js/admin2.js?v=<%= assetVer %>" defer></script>
<script src="/js/assistant.js?v=<%= assetVer %>" defer></script>
<script>
// 询价线索：标记已处理 / 撤销
document.addEventListener('click', function (e) {
  var btn = e.target.closest ? e.target.closest('[data-inq-status]') : null;
  if (!btn) return;
  fetch('/admin/api/inquiry-status', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: Number(btn.getAttribute('data-inq-status')), status: btn.getAttribute('data-next') })
  }).then(function (r) { return r.json(); }).then(function (d) {
    if (d.ok) { try { sessionStorage.setItem('alan-admin-tab', 'leads'); } catch (_) {} location.reload(); }
    else alanToast(d.error || '操作失败 Failed');
  }).catch(function () { alanToast('网络错误 Network error'); });
});
</script>
</body>
</html>
